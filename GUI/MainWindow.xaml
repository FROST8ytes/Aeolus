<ui:FluentWindow x:Class="GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
        xmlns:local="clr-namespace:GUI"
        mc:Ignorable="d"
        Title="Aeolus"
        Height="280"
        Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Aeolus"
                     ShowMinimize="False"
                     ShowMaximize="False" />

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16">

                <!-- Update Interval -->
                <ui:CardControl Margin="0,0,0,8"
                                Icon="{ui:SymbolIcon Timer24}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Update Interval" FontWeight="SemiBold" />
                            <TextBlock Text="How often to send data to device (ms)" 
                                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:NumberBox x:Name="UpdateIntervalInput"
                                  Width="120"
                                  Minimum="100"
                                  Maximum="10000"
                                  SpinButtonPlacementMode="Compact"
                                  ValueChanged="UpdateIntervalInput_ValueChanged" />
                </ui:CardControl>

                <!-- Settings Expander -->
                <ui:CardExpander Margin="0,0,0,8"
                                 Icon="{ui:SymbolIcon Settings24}"
                                 Header="Settings"
                                 IsExpanded="False">
                    <StackPanel>
                        <!-- Close to Tray -->
                        <ui:CardControl Margin="0,0,0,8"
                                        Icon="{ui:SymbolIcon TrayItemRemove24}">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Close to Tray" FontWeight="SemiBold" />
                                    <TextBlock Text="Minimize to system tray when closing" 
                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="12" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:ToggleSwitch x:Name="CloseToTrayToggle"
                                             Checked="CloseToTrayToggle_Changed"
                                             Unchecked="CloseToTrayToggle_Changed" />
                        </ui:CardControl>

                        <!-- Start Minimized -->
                        <ui:CardControl Margin="0,0,0,8"
                                        Icon="{ui:SymbolIcon ArrowMinimize24}">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Start Minimized" FontWeight="SemiBold" />
                                    <TextBlock Text="Start application minimized to tray" 
                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="12" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:ToggleSwitch x:Name="StartMinimizedToggle"
                                             Checked="StartMinimizedToggle_Changed"
                                             Unchecked="StartMinimizedToggle_Changed" />
                        </ui:CardControl>

                        <!-- Run at Startup -->
                        <ui:CardControl Margin="0,0,0,8"
                                        Icon="{ui:SymbolIcon Power24}">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Run at Startup" FontWeight="SemiBold" />
                                    <TextBlock Text="Automatically start with Windows" 
                                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="12" />
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:ToggleSwitch x:Name="RunAtStartupToggle"
                                             Checked="RunAtStartupToggle_Changed"
                                             Unchecked="RunAtStartupToggle_Changed" />
                        </ui:CardControl>
                    </StackPanel>
                </ui:CardExpander>

            </StackPanel>
        </ScrollViewer>

        <!-- System Tray Icon -->
        <tray:NotifyIcon x:Name="TrayIcon"
                         Grid.Row="0"
                         FocusOnLeftClick="True"
                         MenuOnRightClick="True"
                         TooltipText="Aeolus"
                         LeftClick="TrayIcon_LeftClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem Header="Show" Click="TrayMenu_Show_Click" />
                    <Separator />
                    <ui:MenuItem Header="Exit" Click="TrayMenu_Exit_Click" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</ui:FluentWindow>
